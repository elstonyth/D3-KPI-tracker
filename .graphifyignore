# .graphifyignore — controls what graphify indexes.
# graphify uses THIS file instead of .gitignore when it exists, so the whole
# .gitignore is replicated below to keep node_modules/.claude/etc. excluded.
# The "graphify scope" block at the end adds the noise we deliberately prune
# from the knowledge graph (i18n string bundles, dependency lists, static
# images) so `graphify update` and the commit hook stay consistent with the
# clean graph instead of re-polluting it.

# ===== replicated from .gitignore =====
# compiled output
dist
tmp
/out-tsc
.env
# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*

